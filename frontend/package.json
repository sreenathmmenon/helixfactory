    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "d3": "^7.9.0",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "graphology-layout-forceatlas2": "^0.10.1",
    "lucide-react": "^0.468.0",
    "postcss": "^8.4.0",
    "pptxgenjs": "^4.0.1",
